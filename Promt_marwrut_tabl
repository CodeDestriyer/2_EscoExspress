## GAS МЕТОДИ — ПОВНИЙ СПИСОК

```javascript
action: 'getRouteRecords'
// { city_sheet, filters: { type, status, pay_status, date_from, date_to } }

action: 'addParcelToRoute'
// { city_sheet, rte_id, data } → Marhrut + Posylki

action: 'updateRouteRecord'
// { city_sheet, row_index, col, value } — тільки посилки

action: 'getRouteByRteId'
// { city_sheet, rte_id } → всі записи рейсу для PDF

action: 'getDispatches'
// { city_sheet, filters: { date_from, date_to, driver, search } }

action: 'updateDispatch'
// { city_sheet, dispatch_id, col, value }

action: 'getDispatchByRoute'
// { city_sheet, rte_id } → для PDF відправки

action: 'getExpenses'
// { city_sheet, rte_id } → read-only

action: 'getSummary'
// { rte_id? } → read-only
```

